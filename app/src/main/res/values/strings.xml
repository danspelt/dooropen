    <string name="help_title">How to get your credentials</string>
    <string name="help_step1">1. Open the SwitchBot app on your phone.</string>
    <string name="help_step2">2. Tap Profile (bottom right) → Preferences.</string>
    <string name="help_step3">3. Scroll to the app version number and tap it 10 times until "Developer options" appears.</string>
    <string name="help_step4">4. Tap Developer options — copy your Open Token and Secret Key.</string>
    <string name="help_step5">5. Go to Devices, tap your Bot → its Device ID is shown in the detail screen (or copy it from the share sheet).</string>
    <string name="help_step6">6. Paste Token, Secret, and Device ID into the fields below, then tap Save.</string>
